# Supabase-project (Settings -> API in het Supabase-dashboard)
# Gebruik een EU-regio (bv. Frankfurt) voor GDPR-compliance.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key - enkel server-side gebruikt (GDPR-verwijdering van accounts).
# NOOIT naar de client sturen of committen.
SUPABASE_SERVICE_ROLE_KEY=

# Fase 2 (nog niet gebruikt) - Odoo Online koppeling
ODOO_URL=
ODOO_DB=
ODOO_API_KEY=
